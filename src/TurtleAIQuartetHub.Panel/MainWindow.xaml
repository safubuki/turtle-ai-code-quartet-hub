        <Button x:Name="StandardJumpButton"
                Content="&#xE740;"
                Width="26"
                FontFamily="Segoe MDL2 Assets"
                FontSize="12"
                FontWeight="SemiBold"
                Visibility="Collapsed"
                ToolTip="標準表示へ戻す"
                Click="StandardJumpButton_Click"
                Style="{StaticResource ChromeButton}" />
        <Button x:Name="DisplayModeButton"
                Content="&#xE73F;"
                Width="30"
                FontFamily="Segoe MDL2 Assets"
                FontSize="12"
                FontWeight="SemiBold"
                ToolTip="縮小表示へ切り替え"
                Click="DisplayModeButton_Click"
                Style="{StaticResource ChromeButton}" />
        <Button Content="_"
                ToolTip="最小化"
                Click="MinimizeButton_Click"
                Style="{StaticResource ChromeButton}"
                Margin="2,0,0,0" />
        <Button Content="X"
                ToolTip="パネルを閉じる"
