                           Foreground="{StaticResource MutedTextBrush}" />
              </StackPanel>
            </Grid>

            <Border Grid.Row="1"
                    Margin="0,14,0,0"
                    Padding="10,8"
                    Background="#1D2420"
                    BorderBrush="{StaticResource BorderBrushSoft}"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel>
                <TextBlock x:Name="DeleteStoredPanelDetailText"
                           FontWeight="SemiBold"
