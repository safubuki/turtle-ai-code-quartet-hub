    <Border x:Name="SettingsOverlay"
            Grid.RowSpan="5"
            Visibility="Collapsed"
            Background="#96090B0A"
            Panel.ZIndex="22">
      <Grid>
        <Border MaxWidth="610"
                MaxHeight="500"
                Margin="14"
                Padding="16"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel>
                <TextBlock Text="設定"
                           FontSize="16"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="SettingsConfigPathText"
                           Margin="0,4,0,0"
                           FontSize="10"
                           Foreground="{StaticResource MutedTextBrush}"
                           TextWrapping="Wrap" />
              </StackPanel>
              <Button Grid.Column="1"
                      Content="X"
                      ToolTip="閉じる"
                      Click="CloseSettingsButton_Click"
                      Style="{StaticResource ChromeButton}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,0"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <Border Padding="10"
                        Background="#111815"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="アプリケーションパス"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBlock Margin="0,4,0,8"
                               Text="空欄は自動検出を使います。パスが変わった場合は exe/cmd/lnk またはコマンド名を指定してください。"
                               Foreground="{StaticResource MutedTextBrush}"
                               TextWrapping="Wrap" />
                    <ItemsControl ItemsSource="{Binding ApplicationPathSettings}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:ApplicationPathSetting}">
                          <Grid Margin="0,0,0,8">
                            <Grid.ColumnDefinitions>
                              <ColumnDefinition Width="92" />
                              <ColumnDefinition Width="58" />
                              <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                              <RowDefinition Height="Auto" />
                              <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <TextBlock Text="{Binding ShortName}"
                                       Foreground="{StaticResource TextBrush}"
                                       FontWeight="SemiBold" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding KindText}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="10" />
                            <TextBox Grid.Column="2"
                                     Text="{Binding Command, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding ToolTip}"
                                     Style="{StaticResource SettingsTextBoxStyle}" />
                            <TextBlock Grid.Row="1"
                                       Grid.Column="2"
                                       Margin="0,2,0,0"
                                       Text="{Binding ResolvedCommand}"
                                       Foreground="{StaticResource MutedTextBrush}"
                                       FontSize="10"
                                       TextWrapping="Wrap" />
                          </Grid>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="#111815"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="表の Quartet"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <ItemsControl Margin="0,8,0,0"
                                  ItemsSource="{Binding Slots}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:WindowSlot}">
                          <Border Margin="0,0,0,8"
                                  Padding="8"
                                  Background="#151D19"
                                  BorderBrush="#2A3A31"
                                  BorderThickness="1"
                                  CornerRadius="7">
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <TextBlock Text="{Binding Name}"
                                         Foreground="{StaticResource AccentBrush}"
                                         FontWeight="SemiBold" />
                              <TextBox Grid.Column="1"
                                       Text="{Binding ApplicationId, UpdateSourceTrigger=LostFocus}"
                                       ToolTip="vscode / antigravity / codex / claude / github-copilot / grok / gemini"
                                       Style="{StaticResource SettingsTextBoxStyle}" />
                              <Button Grid.Column="2"
                                      Content="空にする"
                                      Tag="{Binding}"
                                      Click="SettingsClearVisibleSlotButton_Click"
                                      Style="{StaticResource StoredAssignButton}"
                                      Margin="8,0,0,0" />

                              <TextBlock Grid.Row="1"
                                         Text="名前"
                                         Foreground="{StaticResource MutedTextBrush}"
                                         FontSize="10" />
                              <TextBox Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PanelTitle, UpdateSourceTrigger=LostFocus}"
                                       Style="{StaticResource SettingsTextBoxStyle}"
                                       Margin="0,4,0,0" />

                              <TextBlock Grid.Row="2"
                                         Text="パス"
                                         Foreground="{StaticResource MutedTextBrush}"
                                         FontSize="10" />
                              <TextBox Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding Path, UpdateSourceTrigger=LostFocus}"
                                       Style="{StaticResource SettingsTextBoxStyle}"
                                       Margin="0,4,0,0" />

                              <TextBlock Grid.Row="3"
                                         Text="保存済"
                                         Foreground="{StaticResource MutedTextBrush}"
                                         FontSize="10" />
                              <Grid Grid.Row="3"
                                    Grid.Column="1"
                                    Grid.ColumnSpan="2"
                                    Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                  <ColumnDefinition Width="*" />
                                  <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBox Text="{Binding SavedWorkspacePath, UpdateSourceTrigger=LostFocus}"
                                         Style="{StaticResource SettingsTextBoxStyle}" />
                                <CheckBox Grid.Column="1"
                                          Margin="8,0,0,0"
                                          VerticalAlignment="Center"
                                          IsChecked="{Binding SavedWorkspaceConfirmed}"
                                          Foreground="{StaticResource MutedTextBrush}"
                                          Content="再利用" />
                              </Grid>
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="#111815"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="控え Quartet"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <ItemsControl Margin="0,8,0,0"
                                  ItemsSource="{Binding StoredPanels}">
                      <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type models:StoredPanelSlot}">
                          <Border Margin="0,0,0,8"
                                  Padding="8"
                                  Background="#151D19"
                                  BorderBrush="#2A3A31"
                                  BorderThickness="1"
                                  CornerRadius="7">
                            <Grid>
                              <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                              </Grid.RowDefinitions>
                              <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="58" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                              </Grid.ColumnDefinitions>

                              <TextBlock Text="{Binding Label}"
                                         Foreground="{StaticResource AccentBrush}"
                                         FontWeight="SemiBold" />
                              <TextBox Grid.Column="1"
                                       Text="{Binding ApplicationId, UpdateSourceTrigger=LostFocus}"
                                       ToolTip="vscode / antigravity / codex / claude / github-copilot / grok / gemini"
                                       Style="{StaticResource SettingsTextBoxStyle}" />
                              <Button Grid.Column="2"
                                      Content="空にする"
                                      Tag="{Binding}"
                                      Click="SettingsClearStoredPanelButton_Click"
                                      Style="{StaticResource StoredAssignButton}"
                                      Margin="8,0,0,0" />

                              <TextBlock Grid.Row="1"
                                         Text="名前"
                                         Foreground="{StaticResource MutedTextBrush}"
                                         FontSize="10" />
                              <TextBox Grid.Row="1"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding PanelTitle, UpdateSourceTrigger=LostFocus}"
                                       Style="{StaticResource SettingsTextBoxStyle}"
                                       Margin="0,4,0,0" />

                              <TextBlock Grid.Row="2"
                                         Text="パス"
                                         Foreground="{StaticResource MutedTextBrush}"
                                         FontSize="10" />
                              <TextBox Grid.Row="2"
                                       Grid.Column="1"
                                       Grid.ColumnSpan="2"
                                       Text="{Binding WorkspacePath, UpdateSourceTrigger=LostFocus}"
                                       Style="{StaticResource SettingsTextBoxStyle}"
                                       Margin="0,4,0,0" />
                            </Grid>
                          </Border>
                        </DataTemplate>
                      </ItemsControl.ItemTemplate>
                    </ItemsControl>
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="2"
                  Margin="0,14,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <StackPanel Orientation="Horizontal">
                <Button Content="不整合を修復"
                        Click="RepairPanelStateButton_Click"
                        Style="{StaticResource BaseButton}"
                        MinWidth="112"
                        Margin="0,0,8,0" />
                <Button Content="再検出"
                        Click="ReloadApplicationDetectionButton_Click"
                        Style="{StaticResource BaseButton}"
                        MinWidth="86" />
              </StackPanel>
              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          HorizontalAlignment="Right">
                <Button Content="パス設定を保存"
                        Click="SaveApplicationPathSettingsButton_Click"
                        Style="{StaticResource BaseButton}"
                        MinWidth="122"
                        Margin="0,0,8,0" />
                <Button x:Name="CloseSettingsDialogButton"
                        Content="閉じる"
                        Click="CloseSettingsButton_Click"
                        Style="{StaticResource BaseButton}"
                        MinWidth="86" />
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
      </Grid>
    </Border>

    <Border x:Name="HelpOverlay"
            Grid.RowSpan="5"
            Visibility="Collapsed"
            Background="#96090B0A"
            Panel.ZIndex="23">
      <Grid>
        <Border Width="486"
                MaxWidth="520"
                Padding="16"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrushSoft}"
                BorderThickness="1"
                CornerRadius="12"
                HorizontalAlignment="Center"
                VerticalAlignment="Center">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock Text="ヘルプ"
                         FontSize="16"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextBrush}" />
              <Button Grid.Column="1"
                      Content="X"
                      ToolTip="閉じる"
                      Click="CloseHelpButton_Click"
                      Style="{StaticResource ChromeButton}" />
            </Grid>

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,0"
                          MaxHeight="430"
                          VerticalScrollBarVisibility="Auto">
              <StackPanel>
                <Border Padding="10"
                        Background="#111815"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="CLI のインストール"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBox Margin="0,6,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="{StaticResource MutedTextBrush}"
                             Text="IDE と Windows アプリは、各製品の公式サイトを参照してください。CLI のインストールコマンドは下記を参照してください。" />
                    <TextBox Margin="0,8,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             FontFamily="Consolas"
                             Foreground="{StaticResource TextBrush}"
                             Text="Codex CLI: npm i -g @openai/codex&#x0a;GitHub Copilot CLI: npm install -g @github/copilot&#x0a;Gemini CLI: npm install -g @google/gemini-cli&#x0a;Claude Code PowerShell: irm https://claude.ai/install.ps1 | iex&#x0a;Claude Code CMD: curl -fsSL https://claude.ai/install.cmd -o install.cmd &amp;&amp; install.cmd &amp;&amp; del install.cmd&#x0a;Claude Code npm: npm install -g @anthropic-ai/claude-code&#x0a;Grok Build CLI (Git Bash/WSL): curl -fsSL https://x.ai/cli/install.sh | bash&#x0a;Grok Build CLI (PowerShell + Git Bash): &amp; &quot;C:\Program Files\Git\bin\bash.exe&quot; -c &quot;curl -fsSL https://x.ai/cli/install.sh | bash&quot;" />
                  </StackPanel>
                </Border>

                <Border Margin="0,12,0,0"
                        Padding="10"
                        Background="#111815"
                        BorderBrush="{StaticResource BorderBrushSoft}"
                        BorderThickness="1"
                        CornerRadius="8">
                  <StackPanel>
                    <TextBlock Text="自律実行向けの起動オプション"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextBrush}" />
                    <TextBox Margin="0,6,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             Foreground="#F2B7AF"
                             Text="下記は承認確認を減らす、または権限を広げるための例です。信頼できるワークスペースでのみ使い、内容が不明なリポジトリでは使わないでください。" />
                    <TextBox Margin="0,8,0,0"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             BorderThickness="0"
                             Background="Transparent"
                             FontFamily="Consolas"
                             Foreground="{StaticResource TextBrush}"
                             Text="codex --ask-for-approval never --sandbox workspace-write&#x0a;copilot --allow-all&#x0a;gemini --approval-mode=yolo&#x0a;claude --permission-mode bypassPermissions&#x0a;grok --always-approve" />
                  </StackPanel>
                </Border>
              </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
              <Button x:Name="CloseHelpDialogButton"
                      Content="閉じる"
                      Click="CloseHelpButton_Click"
                      Style="{StaticResource BaseButton}"
                      MinWidth="96" />
            </StackPanel>
          </Grid>
        </Border>
      </Grid>
    </Border>
  </Grid>
  </Border>
</Window>
