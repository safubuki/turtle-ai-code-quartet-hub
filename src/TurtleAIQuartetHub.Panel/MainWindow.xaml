    <ScrollViewer x:Name="StandardSlotsGrid"
                  Grid.Row="1"
                  VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="False"
                  Padding="0,0,4,0">
      <UniformGrid Columns="2"
                   Rows="2"
                   VerticalAlignment="Top">
        <ContentControl
                        Content="{Binding Slots[0]}"
                        ContentTemplate="{StaticResource SlotCardTemplate}"
                        Margin="5" />
        <ContentControl
                        Content="{Binding Slots[1]}"
                        ContentTemplate="{StaticResource SlotCardTemplate}"
                        Margin="5" />
        <ContentControl
                        Content="{Binding Slots[2]}"
                        ContentTemplate="{StaticResource SlotCardTemplate}"
                        Margin="5" />
        <ContentControl
                        Content="{Binding Slots[3]}"
                        ContentTemplate="{StaticResource SlotCardTemplate}"
                        Margin="5" />
      </UniformGrid>
    </ScrollViewer>

    <Border x:Name="CompactBarPanel"
            Grid.Row="1"
            Visibility="Collapsed"
            Margin="5,3,5,0"
            Padding="3"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <ContentControl Grid.Row="0"
                        Grid.Column="0"
                        Content="{Binding Slots[0]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,3" />
        <ContentControl Grid.Row="0"
                        Grid.Column="1"
                        Content="{Binding Slots[1]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,3" />
        <ContentControl Grid.Row="1"
                        Grid.Column="0"
                        Content="{Binding Slots[2]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,0" />
        <ContentControl Grid.Row="1"
                        Grid.Column="1"
                        Content="{Binding Slots[3]}"
                        ContentTemplate="{StaticResource CompactSlotTemplate}"
                        Margin="0,0,3,0" />

        <Button x:Name="CompactVisibilityButton"
                Grid.Row="0"
                Grid.RowSpan="2"
                Grid.Column="0"
                Grid.ColumnSpan="2"
                Width="22"
                Height="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Panel.ZIndex="2"
                Content="非"
                ToolTip="管理中ウィンドウを非表示"
                Click="CompactVisibilityButton_Click"
                Style="{StaticResource MicroCenterButtonStyle}" />

        <Button Grid.Row="0"
                Grid.Column="2"
                Content="前"
                Click="PinAllTopButton_Click"
                Style="{StaticResource CompactBarActionButtonStyle}"
                Margin="0,0,0,3" />
        <Button Grid.Row="1"
                Grid.Column="2"
                Content="背"
                Click="SendAllBackButton_Click"
                Style="{StaticResource CompactBarActionButtonStyle}" />
      </Grid>
    </Border>

    <Border x:Name="MicroPanel"
            Grid.Row="1"
            Visibility="Collapsed"
            Margin="2,3,2,4"
            Padding="2"
            Height="64"
            Background="{StaticResource SurfaceBrush}"
            BorderBrush="{StaticResource BorderBrushSoft}"
            BorderThickness="1"
            CornerRadius="8">
      <Grid>
        <UniformGrid Rows="2" Columns="2">
          <ContentControl Content="{Binding Slots[0]}"
                          ContentTemplate="{StaticResource MicroSlotTemplate}" />
          <ContentControl Content="{Binding Slots[1]}"
                          ContentTemplate="{StaticResource MicroSlotTemplate}" />
          <ContentControl Content="{Binding Slots[2]}"
                          ContentTemplate="{StaticResource MicroSlotTemplate}" />
          <ContentControl Content="{Binding Slots[3]}"
                          ContentTemplate="{StaticResource MicroSlotTemplate}" />
        </UniformGrid>

        <!-- 4 面の交差点に重ねた円形ボタン。スロット配置の空間メタファーを保ったまま
             全体に効くアクション(全ウィンドウの表示/非表示トグル)を表す。 -->
        <Button x:Name="MicroVisibilityButton"
                Width="22"
                Height="22"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Content="非"
                ToolTip="管理中ウィンドウを非表示"
                Click="MicroVisibilityButton_Click"
                Style="{StaticResource MicroCenterButtonStyle}" />
      </Grid>
    </Border>

    <Grid x:Name="StoredPanelsRowGrid" Grid.Row="2" Margin="5,2,5,3">
      <Expander x:Name="StoredPanelsExpander"
                Style="{StaticResource StoredPanelsExpanderStyle}"
                IsExpanded="False"
                Expanded="StoredPanelsExpander_Expanded"
                Collapsed="StoredPanelsExpander_Collapsed"
                Margin="0">
        <Expander.Header>
          <TextBlock Text="控え Quartet（クリックで開く）"
                     Foreground="{StaticResource TextBrush}"
                     FontSize="12"
                     FontWeight="SemiBold" />
        </Expander.Header>
            <Border x:Name="StoredPanelsExpanderContent"
              Background="{StaticResource SurfaceBrush}"
              BorderBrush="{StaticResource BorderBrushSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Margin="0,12,0,0"
              Padding="6">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <ItemsControl ItemsSource="{Binding StoredPanelPages}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <StackPanel Orientation="Horizontal" />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type models:StoredPanelPage}">
                <Button Content="{Binding Header}"
                        Tag="{Binding}"
                        Click="StoredPanelPageTab_Click"
                        Style="{StaticResource StoredPageTabButtonStyle}" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <ContentControl Grid.Row="1"
                          Content="{Binding SelectedStoredPanelPage}"
                          ContentTemplate="{StaticResource StoredPanelPageTemplate}" />
        </Grid>
      </Border>
      </Expander>

      <StackPanel Orientation="Horizontal"
                  HorizontalAlignment="Right"
                  VerticalAlignment="Top"
                  Margin="0,4,4,0"
                  Panel.ZIndex="2">
        <TextBlock Text="Windows"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="10"
                   FontWeight="SemiBold"
                   Margin="0,0,4,0" />
        <ItemsControl x:Name="AuxiliaryApplicationPanel"
                      ItemsSource="{Binding AuxiliaryApplications}">
          <ItemsControl.ItemsPanel>
            <ItemsPanelTemplate>
              <StackPanel Orientation="Horizontal" />
            </ItemsPanelTemplate>
          </ItemsControl.ItemsPanel>
          <ItemsControl.ItemContainerStyle>
            <Style TargetType="ContentPresenter">
              <Setter Property="Margin" Value="4,0,0,0" />
            </Style>
          </ItemsControl.ItemContainerStyle>
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type models:LauncherApplication}">
              <Button Content="{Binding ShortName}"
                      Tag="{Binding}"
                      Click="AuxiliaryApplicationButton_Click"
                      Style="{StaticResource AuxiliaryApplicationButtonStyle}" />
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </Grid>

    <Grid x:Name="FooterControlsGrid" Grid.Row="3" Margin="5,2,5,3">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Border Background="{StaticResource SurfaceAltBrush}"
              BorderBrush="{StaticResource BorderBrushSoft}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="7,4"
                Margin="0,0,5,0">
        <TextBlock Text="{Binding Message}"
                   Foreground="{StaticResource MutedTextBrush}"
                   FontSize="10"
                   TextWrapping="Wrap" />
      </Border>

      <StackPanel Grid.Column="1"
                  VerticalAlignment="Center"
                  Width="290">
        <Grid Margin="0,0,0,4">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="3*" />
            <ColumnDefinition Width="5*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
            x:Name="TopmostAllButton"
            Content="最前面"
            Click="PinAllTopButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="1"
            x:Name="BackmostAllButton"
            Content="最背面"
            Click="SendAllBackButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="2"
            x:Name="ToggleVisibilityButton"
            Content="非表示"
            Click="ToggleVisibilityButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="3"
            x:Name="ToggleMonitorButton"
            Content="ディスプレイ移動"
            Click="ToggleMonitorButton_Click"
                  Style="{StaticResource BarButton}" />
        </Grid>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="9*" />
            <ColumnDefinition Width="9*" />
            <ColumnDefinition Width="10*" />
          </Grid.ColumnDefinitions>

          <Button Grid.Column="0"
                  x:Name="SaveSettingsButton"
                  Content="設定保存"
                  Click="SaveSettingsButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="1"
                  x:Name="LoadSettingsButton"
                  Content="設定読み込み"
                  Click="LoadSettingsButton_Click"
                  Style="{StaticResource BarButton}"
                  Margin="0,0,4,0" />
          <Button Grid.Column="2"
                  x:Name="CloseAllButton"
                  Content="すべて閉じる"
                  Click="CloseAllButton_Click"
                  Style="{StaticResource BarButton}" />
        </Grid>
      </StackPanel>
    </Grid>

    <Grid Grid.Row="4"
          x:Name="ApplicationLauncherPanel"
          Margin="5,5,5,0">
      <Button x:Name="LaunchButton"
              Click="LaunchButton_Click"
              ToolTip="{Binding LaunchButtonToolTip}"
              Style="{StaticResource LaunchButtonStyle}"
              HorizontalAlignment="Stretch">
        <TextBlock Text="{Binding LaunchButtonText}" />
      </Button>
    </Grid>

    <Border x:Name="CloseAllConfirmOverlay"
            Grid.RowSpan="5"
            Visibility="Collapsed"
            Background="#96090B0A"
