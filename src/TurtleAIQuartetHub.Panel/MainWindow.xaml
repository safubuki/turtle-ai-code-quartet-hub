                    CornerRadius="8">
              <StackPanel>
                <TextBlock x:Name="ClearSlotInfoDetailText"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource TextBrush}" />
                <TextBlock x:Name="ClearSlotInfoPathText"
                           Margin="0,4,0,0"
