            <TextBlock Grid.Row="2"
                       Margin="0,12,0,0"
                       Text="削除すると、タイトル、保存済みワークスペース、選択アプリ、ウィンドウ割り当てが消えます。起動中のIDE / CLIウィンドウも閉じます。"
                       Foreground="#F2B7AF"
                       TextWrapping="Wrap" />

            <StackPanel Grid.Row="3"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
              <Button x:Name="CancelClearSlotInfoButton"
                      Content="キャンセル"
