<Window x:Class="TurtleAIQuartetHub.Panel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:models="clr-namespace:TurtleAIQuartetHub.Panel.Models"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="Turtle AI Code Quartet Hub"
        Width="650"
        Height="535"
        MinWidth="560"
        MinHeight="520"
        Background="#101211"
        Foreground="#EEF4EF"
        FontFamily="Segoe UI"
        FontSize="12"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        Topmost="True"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        Icon="app.ico"
        PreviewMouseDown="Window_PreviewMouseDown">
  <shell:WindowChrome.WindowChrome>
    <shell:WindowChrome CaptionHeight="34"
                        ResizeBorderThickness="0"
                        GlassFrameThickness="0"
                        CornerRadius="0"
                        UseAeroCaptionButtons="False" />
  </shell:WindowChrome.WindowChrome>

  <Window.Resources>
    <SolidColorBrush x:Key="PanelBackgroundBrush" Color="#101211" />
    <SolidColorBrush x:Key="SurfaceBrush" Color="#171B19" />
    <SolidColorBrush x:Key="SurfaceAltBrush" Color="#1D2420" />
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#2E3832" />
    <SolidColorBrush x:Key="TextBrush" Color="#EEF4EF" />
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9AA59E" />
    <SolidColorBrush x:Key="AccentBrush" Color="#45D483" />
    <SolidColorBrush x:Key="AccentDarkBrush" Color="#123222" />
    <Style TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
    </Style>

    <Style x:Key="InlineTitleTextBox" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="2,1" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TextBox">
            <Border x:Name="EditorBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="6">
              <ScrollViewer x:Name="PART_ContentHost"
                            Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="EditorBorder" Property="Background" Value="#202823" />
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#4C6B59" />
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="EditorBorder" Property="BorderBrush" Value="#3A453E" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="IsReadOnly" Value="True" />
      <Setter Property="Focusable" Value="False" />
      <Setter Property="Cursor" Value="Arrow" />
      <EventSetter Event="PreviewKeyDown" Handler="InlineTitleTextBox_PreviewKeyDown" />
      <EventSetter Event="PreviewMouseLeftButtonDown" Handler="InlineTitleTextBox_PreviewMouseLeftButtonDown" />
      <EventSetter Event="LostKeyboardFocus" Handler="InlineTitleTextBox_LostKeyboardFocus" />
    </Style>

    <Style x:Key="SettingsTextBoxStyle" TargetType="TextBox">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#121816" />
      <Setter Property="BorderBrush" Value="#2E3832" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="SelectionBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style x:Key="BaseButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="Background" Value="#202823" />
      <Setter Property="BorderBrush" Value="#3A453E" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="11,6" />
      <Setter Property="MinHeight" Value="30" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#2B352F" />
                <Setter TargetName="ButtonBorder" Property="BorderBrush" Value="#53645A" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#18201B" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="LaunchButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Foreground" Value="#06120C" />
      <Setter Property="Background" Value="{StaticResource AccentBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="15" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="MinHeight" Value="34" />
      <Setter Property="Padding" Value="10,5" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
      <Setter Property="TextOptions.TextRenderingMode" Value="Auto" />
    </Style>

    <Style x:Key="MiniButton" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Padding" Value="8,4" />
      <Setter Property="MinHeight" Value="26" />
      <Setter Property="MinWidth" Value="54" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Background" Value="#17201B" />
      <Setter Property="BorderBrush" Value="#385345" />
    </Style>

    <Style x:Key="BarButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="6,3" />
      <Setter Property="Background" Value="#1B221E" />
      <Setter Property="HorizontalAlignment" Value="Stretch" />
    </Style>

    <Style x:Key="ApplicationSelectorButtonStyle" TargetType="Button" BasedOn="{StaticResource BarButton}">
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="5,1" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Setter Property="ToolTip" Value="{Binding ToolTip}" />
      <Setter Property="IsEnabled" Value="{Binding IsAvailable}" />
      <Setter Property="Background" Value="#17201B" />
      <Setter Property="BorderBrush" Value="#344A3E" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsSelected}" Value="True">
          <Setter Property="Foreground" Value="#E9FFF2" />
          <Setter Property="Background" Value="#263F31" />
          <Setter Property="BorderBrush" Value="#59D58E" />
          <Setter Property="FontWeight" Value="SemiBold" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsAvailable}" Value="False">
          <Setter Property="Foreground" Value="#66716A" />
          <Setter Property="Background" Value="#121816" />
          <Setter Property="BorderBrush" Value="#27322C" />
          <Setter Property="FontWeight" Value="Normal" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="CliApplicationOptionTemplate" DataType="{x:Type models:SlotApplicationOption}">
      <Button Tag="{Binding}"
              Click="SlotApplicationSwitchButton_Click"
              ToolTip="{Binding ToolTip}"
              ToolTipService.ShowOnDisabled="True"
              Style="{StaticResource ApplicationSelectorButtonStyle}">
        <TextBlock Text="{Binding ShortName}"
                   TextTrimming="CharacterEllipsis"
                   TextAlignment="Center" />
      </Button>
    </DataTemplate>

    <Style x:Key="ApplicationGroupBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="#121816" />
      <Setter Property="BorderBrush" Value="#2B3D34" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="7" />
      <Setter Property="Padding" Value="6,8,6,4" />
    </Style>

    <Style x:Key="ApplicationGroupLabelStyle" TargetType="TextBlock">
      <Setter Property="Foreground" Value="#A9B7B0" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="FontSize" Value="9" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Padding" Value="5,0" />
      <Setter Property="HorizontalAlignment" Value="Left" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Setter Property="Margin" Value="8,-5,0,0" />
    </Style>

    <Style x:Key="AuxiliaryApplicationButtonStyle" TargetType="Button" BasedOn="{StaticResource BarButton}">
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Width" Value="82" />
      <Setter Property="Height" Value="24" />
      <Setter Property="FontSize" Value="10.5" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Setter Property="ToolTip" Value="{Binding ToolTip}" />
      <Setter Property="IsEnabled" Value="{Binding IsAvailable}" />
      <Setter Property="Background" Value="#0E2030" />
      <Setter Property="BorderBrush" Value="#2C6888" />
    </Style>

    <Style x:Key="VisibilityRestoreButtonStyle" TargetType="Button" BasedOn="{StaticResource BarButton}">
      <Setter Property="Foreground" Value="#1A1406" />
      <Setter Property="Background" Value="#F2CA57" />
      <Setter Property="BorderBrush" Value="#FFF0B5" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="CompactBarActionButtonStyle" TargetType="Button" BasedOn="{StaticResource BarButton}">
      <Setter Property="MinHeight" Value="18" />
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Padding" Value="4,0" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
    </Style>

    <Style x:Key="SlotActionButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="MinWidth" Value="64" />
    </Style>

    <Style x:Key="StoredAssignButton" TargetType="Button" BasedOn="{StaticResource MiniButton}">
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Padding" Value="4,2" />
      <Setter Property="FontSize" Value="10" />
    </Style>

    <Style x:Key="StoredDeleteButton" TargetType="Button" BasedOn="{StaticResource StoredAssignButton}">
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#F2B7AF" />
      <Setter Property="Background" Value="#261816" />
      <Setter Property="BorderBrush" Value="#6A3832" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="ToolTip" Value="この控えを削除" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding HasContent}" Value="False">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SlotClearInfoButtonStyle" TargetType="Button" BasedOn="{StaticResource StoredAssignButton}">
      <Setter Property="MinWidth" Value="24" />
      <Setter Property="Width" Value="24" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#F2B7AF" />
      <Setter Property="Background" Value="#261816" />
      <Setter Property="BorderBrush" Value="#6A3832" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="ToolTip" Value="このパネル情報を削除" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#FFE7E2" />
          <Setter Property="Background" Value="#33201D" />
          <Setter Property="BorderBrush" Value="#A65348" />
        </Trigger>
        <DataTrigger Binding="{Binding HasPanelContent}" Value="False">
          <Setter Property="IsEnabled" Value="False" />
          <Setter Property="Opacity" Value="0.4" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SlotOpenFolderButtonStyle" TargetType="Button" BasedOn="{StaticResource StoredAssignButton}">
      <Setter Property="MinWidth" Value="28" />
      <Setter Property="Width" Value="28" />
      <Setter Property="Height" Value="24" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Foreground" Value="#DDEFE5" />
      <Setter Property="Background" Value="#17271E" />
      <Setter Property="BorderBrush" Value="#3B604A" />
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
      <Setter Property="FontSize" Value="13" />
      <Setter Property="ToolTip" Value="{Binding WorkspaceFolderToolTip}" />
      <Setter Property="ToolTipService.ShowOnDisabled" Value="True" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Foreground" Value="#F2FFF8" />
          <Setter Property="Background" Value="#203629" />
          <Setter Property="BorderBrush" Value="#6BE49B" />
        </Trigger>
        <DataTrigger Binding="{Binding CanOpenWorkspaceFolder}" Value="False">
          <Setter Property="IsEnabled" Value="False" />
          <Setter Property="Opacity" Value="0.42" />
          <Setter Property="Foreground" Value="#768179" />
          <Setter Property="Background" Value="#151A17" />
          <Setter Property="BorderBrush" Value="#2A332E" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="DangerButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="Foreground" Value="#FFF4F2" />
      <Setter Property="Background" Value="#6F2D27" />
      <Setter Property="BorderBrush" Value="#B3574E" />
      <Setter Property="MinWidth" Value="96" />
      <Setter Property="MinHeight" Value="32" />
      <Setter Property="Padding" Value="12,6" />
    </Style>

    <Style x:Key="ChromeButton" TargetType="Button">
      <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="BorderThickness" Value="0" />
      <Setter Property="Width" Value="32" />
      <Setter Property="Height" Value="28" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="ButtonBorder" Background="{TemplateBinding Background}" CornerRadius="8">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="ButtonBorder" Property="Background" Value="#25302A" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="TinyPill" TargetType="Border">
      <Setter Property="Background" Value="#242B27" />
      <Setter Property="BorderBrush" Value="#3A463F" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="8,3" />
      <Setter Property="MinHeight" Value="24" />
    </Style>

    <Style x:Key="StatusPillTextStyle" TargetType="TextBlock">
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="TextTrimming" Value="CharacterEllipsis" />
      <Setter Property="LineStackingStrategy" Value="BlockLineHeight" />
      <Setter Property="LineHeight" Value="15" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="TextOptions.TextFormattingMode" Value="Ideal" />
      <Setter Property="TextAlignment" Value="Center" />
    </Style>

    <Style x:Key="WindowPillTextStyle" TargetType="TextBlock" BasedOn="{StaticResource StatusPillTextStyle}">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHidden}" Value="True">
          <Setter Property="Foreground" Value="#D4C47A" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="WindowPill" TargetType="Border" BasedOn="{StaticResource TinyPill}">
      <Setter Property="MinWidth" Value="52" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Ready}">
          <Setter Property="Background" Value="{StaticResource AccentDarkBrush}" />
          <Setter Property="BorderBrush" Value="#287B4A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#302817" />
          <Setter Property="BorderBrush" Value="#7B6129" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="#311B1A" />
          <Setter Property="BorderBrush" Value="#79403A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsHidden}" Value="True">
          <Setter Property="Background" Value="#28251A" />
          <Setter Property="BorderBrush" Value="#8B7D3E" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SlotCardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Cursor" Value="Hand" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#1A211D" />
          <Setter Property="BorderBrush" Value="#3D4E45" />
        </Trigger>
        <DataTrigger Binding="{Binding IsFocused}" Value="True">
          <Setter Property="Effect">
            <Setter.Value>
              <DropShadowEffect Color="#45D483"
                                BlurRadius="10"
                                ShadowDepth="0"
                                Opacity="0.3" />
            </Setter.Value>
          </Setter>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactSlotButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="MinHeight" Value="24" />
      <Setter Property="MinWidth" Value="44" />
      <Setter Property="Padding" Value="5,2" />
      <Setter Property="Margin" Value="0" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Stretch" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="CompactFocusFrame"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="2"
                    CornerRadius="8">
              <Border x:Name="CompactButtonBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="7">
                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                  Margin="{TemplateBinding Padding}" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="CompactButtonBorder" Property="Background" Value="#1A211D" />
                <Setter TargetName="CompactButtonBorder" Property="BorderBrush" Value="#3D4E45" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="CompactButtonBorder" Property="Background" Value="#121715" />
              </Trigger>
              <DataTrigger Binding="{Binding IsFocused}" Value="True">
                <Setter TargetName="CompactFocusFrame" Property="BorderBrush" Value="#45D483" />
                <Setter TargetName="CompactButtonBorder" Property="Effect">
                  <Setter.Value>
                    <DropShadowEffect Color="#45D483"
                                      BlurRadius="9"
                                      ShadowDepth="0"
                                      Opacity="0.3" />
                  </Setter.Value>
                </Setter>
              </DataTrigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
          <Setter Property="BorderBrush" Value="#505B55" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#241F15" />
          <Setter Property="BorderBrush" Value="#A27E39" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactSlotBadgeStyle" TargetType="Border">
      <Setter Property="Width" Value="18" />
      <Setter Property="Height" Value="18" />
      <Setter Property="CornerRadius" Value="4" />
      <Setter Property="Background" Value="#223027" />
      <Setter Property="BorderBrush" Value="#335A43" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Margin" Value="0,0,5,0" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="#1B211E" />
          <Setter Property="BorderBrush" Value="#4A5550" />
          <Setter Property="Opacity" Value="0.72" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#2C2414" />
          <Setter Property="BorderBrush" Value="#C49B38" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactSlotBadgeTextStyle" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Center" />
      <Setter Property="VerticalAlignment" Value="Center" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Foreground" Value="#6F7B74" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="MicroCenterButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Background" Value="#101714" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <!-- 円形ボタン: 直径 22 → CornerRadius 11 で完全な円。
                 ContentPresenter は下げ気味の補正で大文字 1 字を視覚的中央に置く。 -->
            <Border x:Name="MicroCenterBorder"
                    Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="{TemplateBinding BorderThickness}"
                    CornerRadius="11">
              <ContentPresenter HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                RenderTransformOrigin="0.5,0.5">
                <ContentPresenter.RenderTransform>
                  <TranslateTransform Y="-1" />
                </ContentPresenter.RenderTransform>
              </ContentPresenter>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="MicroCenterBorder" Property="Background" Value="{StaticResource AccentDarkBrush}" />
                <Setter Property="Foreground" Value="#D8FFE6" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="MicroCenterBorder" Property="Background" Value="#0A1A11" />
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="MicroSlotButtonStyle" TargetType="Button" BasedOn="{StaticResource BaseButton}">
      <Setter Property="MinHeight" Value="0" />
      <Setter Property="MinWidth" Value="0" />
      <Setter Property="Padding" Value="0" />
      <Setter Property="Margin" Value="2" />
      <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
      <Setter Property="FontSize" Value="14" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="HorizontalContentAlignment" Value="Center" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border x:Name="MicroFocusFrame"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    BorderThickness="2"
                    CornerRadius="7">
              <Border x:Name="MicroButtonBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6">
                <ContentPresenter HorizontalAlignment="Center"
                                  VerticalAlignment="Center" />
              </Border>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="MicroButtonBorder" Property="Background" Value="#1A211D" />
                <Setter TargetName="MicroButtonBorder" Property="BorderBrush" Value="#3D4E45" />
              </Trigger>
              <Trigger Property="IsPressed" Value="True">
                <Setter TargetName="MicroButtonBorder" Property="Background" Value="#121715" />
              </Trigger>
              <DataTrigger Binding="{Binding IsFocused}" Value="True">
                <Setter TargetName="MicroFocusFrame" Property="BorderBrush" Value="#45D483" />
                <Setter TargetName="MicroButtonBorder" Property="Background" Value="#123222" />
                <Setter TargetName="MicroButtonBorder" Property="Effect">
                  <Setter.Value>
                    <DropShadowEffect Color="#45D483"
                                      BlurRadius="9"
                                      ShadowDepth="0"
                                      Opacity="0.4" />
                  </Setter.Value>
                </Setter>
              </DataTrigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Opacity" Value="0.45" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
          <Setter Property="BorderBrush" Value="#505B55" />
          <Setter Property="Foreground" Value="#6F7B74" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Background" Value="#241F15" />
          <Setter Property="BorderBrush" Value="#A27E39" />
          <Setter Property="Foreground" Value="#F2CA57" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CompactStatusDotStyle" TargetType="Ellipse">
      <Setter Property="Width" Value="5" />
      <Setter Property="Height" Value="5" />
      <Setter Property="Fill" Value="#54675C" />
      <Setter Property="Stroke" Value="#73847B" />
      <Setter Property="StrokeThickness" Value="0.8" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Fill" Value="#666F6A" />
          <Setter Property="Stroke" Value="#87928B" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Fill" Value="#C9A441" />
          <Setter Property="Stroke" Value="#F2CA57" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="StoredCardBorderStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource SurfaceAltBrush}" />
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Height" Value="118" />
      <Setter Property="MinHeight" Value="118" />
      <Setter Property="MaxHeight" Value="118" />
      <Setter Property="Padding" Value="6" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="VerticalAlignment" Value="Top" />
      <Style.Triggers>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="#202A25" />
          <Setter Property="BorderBrush" Value="#3E5148" />
        </Trigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="StoredPanelsExpanderStyle" TargetType="Expander">
      <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
      <Setter Property="FontSize" Value="12" />
    </Style>

    <Style x:Key="StoredPageTabButtonStyle" TargetType="Button">
      <Setter Property="Foreground" Value="#B9C5BE" />
      <Setter Property="Background" Value="#17201B" />
      <Setter Property="BorderBrush" Value="#4A6658" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="Padding" Value="16,0,16,0" />
      <Setter Property="Margin" Value="0,0,10,4" />
      <Setter Property="MinWidth" Value="82" />
      <Setter Property="Height" Value="22" />
      <Setter Property="MinHeight" Value="22" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="AllowDrop" Value="True" />
      <Setter Property="FontSize" Value="11" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="FocusVisualStyle" Value="{x:Null}" />
      <Setter Property="SnapsToDevicePixels" Value="True" />
      <Setter Property="UseLayoutRounding" Value="True" />
      <EventSetter Event="DragEnter" Handler="StoredPanelTab_DragEnter" />
      <EventSetter Event="DragLeave" Handler="StoredPanelTab_DragLeave" />
      <EventSetter Event="DragOver" Handler="StoredPanelTab_DragOver" />
      <EventSetter Event="Drop" Handler="StoredPanelTab_Drop" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Grid x:Name="TabButtonRoot"
                  Height="{TemplateBinding Height}"
                  MinWidth="{TemplateBinding MinWidth}"
                  ClipToBounds="False"
                  SnapsToDevicePixels="True"
                  UseLayoutRounding="True">
              <Border x:Name="TabButtonBorder"
                      Background="{TemplateBinding Background}"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      BorderThickness="{TemplateBinding BorderThickness}"
                      CornerRadius="6"
                      SnapsToDevicePixels="True"
                      UseLayoutRounding="True" />
              <ContentPresenter ContentSource="Content"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Margin="{TemplateBinding Padding}" />
            </Grid>
            <ControlTemplate.Triggers>
              <DataTrigger Binding="{Binding IsSelected}" Value="True">
                <Setter TargetName="TabButtonBorder" Property="Background" Value="#223027" />
                <Setter TargetName="TabButtonBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
              </DataTrigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="TabButtonBorder" Property="Background" Value="#243029" />
                <Setter TargetName="TabButtonBorder" Property="BorderBrush" Value="#5E7568" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocusWithin" Value="True">
                <Setter TargetName="TabButtonBorder" Property="BorderBrush" Value="#8AFCB7" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="LedIndicatorStyle" TargetType="Ellipse">
      <Setter Property="Width" Value="10" />
      <Setter Property="Height" Value="10" />
      <Setter Property="Fill" Value="#3A4941" />
      <Setter Property="Stroke" Value="#54675C" />
      <Setter Property="StrokeThickness" Value="1" />
      <Setter Property="Margin" Value="0,0,8,0" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsTopmostLayer}" Value="True">
          <Setter Property="Fill" Value="#2E9C5E" />
          <Setter Property="Stroke" Value="#7EF3AF" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsBackmostLayer}" Value="True">
          <Setter Property="Fill" Value="#59655E" />
          <Setter Property="Stroke" Value="#7C8A82" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsFocused}" Value="True">
          <Setter Property="Fill" Value="#7AF7B2" />
          <Setter Property="Stroke" Value="#D7FFE8" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}">
          <Setter Property="Fill" Value="#8C2929" />
          <Setter Property="Stroke" Value="#D96A6A" />
        </DataTrigger>
        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
          <Setter Property="Fill" Value="#C9A441" />
          <Setter Property="Stroke" Value="#FFE18A" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <DataTemplate x:Key="SlotCardTemplate" DataType="{x:Type models:WindowSlot}">
      <Border x:Name="SlotCardFocusFrame"
              Background="Transparent"
              BorderThickness="2"
              CornerRadius="10"
              Tag="{Binding}"
              Cursor="Hand"
              MouseLeftButtonUp="SlotCard_MouseLeftButtonUp"
              PreviewMouseLeftButtonDown="SlotCard_PreviewMouseLeftButtonDown"
              PreviewMouseMove="SlotCard_PreviewMouseMove"
              AllowDrop="True"
              DragEnter="SlotCard_DragEnter"
              DragLeave="SlotCard_DragLeave"
              DragOver="SlotCard_DragOver"
              Drop="SlotCard_Drop">
        <Border x:Name="SlotCardBorder"
                Style="{StaticResource SlotCardBorderStyle}"
                Padding="0">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <Border Width="28"
                      Height="28"
                      CornerRadius="8"
                      Background="#223027"
                      BorderBrush="#335A43"
                      BorderThickness="1"
                      Margin="0,0,8,0">
                <TextBlock Text="{Binding Name}"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"
                           FontWeight="SemiBold"
                           Foreground="{StaticResource AccentBrush}" />
              </Border>
              <Ellipse Grid.Column="1" Style="{StaticResource LedIndicatorStyle}" VerticalAlignment="Center" />
              <StackPanel Grid.Column="2">
                <TextBox Text="{Binding PanelTitle, UpdateSourceTrigger=PropertyChanged}"
                         ToolTip="ダブルクリックで名前を編集"
                         Style="{StaticResource InlineTitleTextBox}"
                         MaxLength="40" />
                <TextBlock Text="{Binding ShortPath}"
                           Margin="0,2,0,0"
                           Foreground="{StaticResource MutedTextBrush}" />
              </StackPanel>
              <Button Grid.Column="3"
                      Content="&#xE74D;"
                      Tag="{Binding}"
                      Click="ClearSlotPanelInfoButton_Click"
                      Style="{StaticResource SlotClearInfoButtonStyle}"
                      VerticalAlignment="Top"
                      Margin="8,0,0,0" />
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,7,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="98" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <Grid Grid.Column="0"
                    Margin="0,0,6,0">
                <Border Style="{StaticResource ApplicationGroupBorderStyle}">
                  <ItemsControl ItemsSource="{Binding IdeApplicationOptions}">
                    <ItemsControl.ItemsPanel>
                      <ItemsPanelTemplate>
                        <StackPanel Orientation="Vertical" />
                      </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                      <Style TargetType="ContentPresenter">
                        <Setter Property="Margin" Value="2,0,2,4" />
                      </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                      <DataTemplate DataType="{x:Type models:SlotApplicationOption}">
                        <Button Tag="{Binding}"
                                Click="SlotApplicationSwitchButton_Click"
                                ToolTip="{Binding ToolTip}"
                                ToolTipService.ShowOnDisabled="True"
                                Style="{StaticResource ApplicationSelectorButtonStyle}">
                          <TextBlock Text="{Binding ShortName}"
                                     TextTrimming="CharacterEllipsis"
                                     TextAlignment="Center" />
                        </Button>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </Border>
                <TextBlock Text="IDE"
                           Style="{StaticResource ApplicationGroupLabelStyle}" />
              </Grid>

              <Grid Grid.Column="1">
                <Border Style="{StaticResource ApplicationGroupBorderStyle}">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <UniformGrid Grid.Row="0"
                                 Columns="2">
                      <ContentControl Content="{Binding CliApplicationOptions[0]}"
                                      ContentTemplate="{StaticResource CliApplicationOptionTemplate}"
                                      Margin="2,0,2,4" />
                      <ContentControl Content="{Binding CliApplicationOptions[1]}"
                                      ContentTemplate="{StaticResource CliApplicationOptionTemplate}"
                                      Margin="2,0,2,4" />
                    </UniformGrid>

                    <Grid Grid.Row="1">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                      </Grid.ColumnDefinitions>

                      <ContentControl Grid.Column="0"
                                      Content="{Binding CliApplicationOptions[2]}"
                                      ContentTemplate="{StaticResource CliApplicationOptionTemplate}"
                                      Margin="2,0,2,4" />
                      <ContentControl Grid.Column="1"
                                      Width="46"
                                      Content="{Binding CliApplicationOptions[3]}"
                                      ContentTemplate="{StaticResource CliApplicationOptionTemplate}"
                                      Margin="2,0,2,4" />
                      <ContentControl Grid.Column="2"
                                      Content="{Binding CliApplicationOptions[4]}"
                                      ContentTemplate="{StaticResource CliApplicationOptionTemplate}"
                                      Margin="2,0,2,4" />
                    </Grid>
                  </Grid>
                </Border>
                <TextBlock Text="CLI"
                           Style="{StaticResource ApplicationGroupLabelStyle}" />
              </Grid>
            </Grid>

            <Grid Grid.Row="2"
                  Margin="0,6,0,0">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>

              <Button Grid.Column="0"
                      Content="&#xE8B7;"
                      Tag="{Binding}"
                      Click="OpenSlotWorkspaceFolderButton_Click"
                      AutomationProperties.Name="ワークスペースフォルダを開く"
                      HorizontalAlignment="Left"
                      VerticalAlignment="Center"
                      Style="{StaticResource SlotOpenFolderButtonStyle}" />

              <StackPanel Grid.Column="1"
                          Orientation="Horizontal"
                          VerticalAlignment="Center">
                <Button Tag="{Binding}"
                        Click="StoreSlotButton_Click"
                        Margin="0,0,6,0">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SlotActionButton}">
                      <Setter Property="Content" Value="控え移動" />
                      <Style.Triggers>
                        <DataTrigger Binding="{Binding HasPanelContent}" Value="False">
                          <Setter Property="IsEnabled" Value="False" />
                          <Setter Property="Opacity" Value="0.4" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
                <Button Tag="{Binding}"
                        Click="SlotMainActionButton_Click"
                        MinWidth="64">
                  <Button.Style>
                    <Style TargetType="Button" BasedOn="{StaticResource SlotActionButton}">
                      <Setter Property="Content" Value="閉じる" />
                      <Style.Triggers>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}" />
                            <Condition Binding="{Binding HasPanelContent}" Value="True" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Content" Value="起動" />
                        </MultiDataTrigger>
                        <MultiDataTrigger>
                          <MultiDataTrigger.Conditions>
                            <Condition Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Missing}" />
                            <Condition Binding="{Binding HasPanelContent}" Value="False" />
                          </MultiDataTrigger.Conditions>
                          <Setter Property="Content" Value="新規" />
                        </MultiDataTrigger>
                        <DataTrigger Binding="{Binding WindowStatus}" Value="{x:Static models:SlotWindowStatus.Launching}">
                          <Setter Property="Content" Value="起動中" />
                          <Setter Property="IsEnabled" Value="False" />
                          <Setter Property="Opacity" Value="0.5" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Button.Style>
                </Button>
              </StackPanel>
            </Grid>
          </Grid>
        </Border>
        <Border.Style>
          <Style TargetType="Border">
            <Setter Property="BorderBrush" Value="Transparent" />
            <Style.Triggers>
              <DataTrigger Binding="{Binding IsFocused}" Value="True">
                <Setter Property="BorderBrush" Value="#45D483" />
              </DataTrigger>
            </Style.Triggers>
          </Style>
        </Border.Style>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="MicroSlotTemplate" DataType="{x:Type models:WindowSlot}">
      <Button Tag="{Binding}"
              Click="MicroSlotButton_Click"
              ToolTip="{Binding DisplayTitle}"
              Style="{StaticResource MicroSlotButtonStyle}">
        <!-- フォントの descender 領域がセル中央計算に含まれるため、
             descender を持たない大文字を視覚的中央へ移すには RenderTransform で
             上方向に補正する。レイアウトには影響せず純粋に描画位置だけ調整。 -->
        <TextBlock Text="{Binding Name}"
                   HorizontalAlignment="Center"
                   VerticalAlignment="Center">
          <TextBlock.RenderTransform>
            <TranslateTransform Y="-1" />
          </TextBlock.RenderTransform>
        </TextBlock>
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="CompactSlotTemplate" DataType="{x:Type models:WindowSlot}">
      <Button Tag="{Binding}"
              Click="CompactSlotButton_Click"
              Style="{StaticResource CompactSlotButtonStyle}">
        <Grid VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Border Style="{StaticResource CompactSlotBadgeStyle}">
            <TextBlock Text="{Binding Name}"
                       Style="{StaticResource CompactSlotBadgeTextStyle}" />
          </Border>

          <TextBlock Grid.Column="1"
                     Text="{Binding DisplayTitle}"
                     ToolTip="{Binding DisplayTitle}"
                     VerticalAlignment="Center"
                     FontSize="12"
                     FontWeight="SemiBold"
                     TextTrimming="CharacterEllipsis"
                     Foreground="{StaticResource TextBrush}" />
        </Grid>
      </Button>
    </DataTemplate>

    <DataTemplate x:Key="StoredPanelTemplate" DataType="{x:Type models:StoredPanelSlot}">
      <Border Style="{StaticResource StoredCardBorderStyle}"
              Tag="{Binding}"
              PreviewMouseLeftButtonDown="StoredPanelCard_PreviewMouseLeftButtonDown"
              PreviewMouseMove="StoredPanelCard_PreviewMouseMove"
              AllowDrop="True"
              DragEnter="StoredPanelCard_DragEnter"
              DragLeave="StoredPanelCard_DragLeave"
              DragOver="StoredPanelCard_DragOver"
              Drop="StoredPanelCard_Drop">
        <Grid Height="104">
          <Grid.RowDefinitions>
            <RowDefinition Height="24" />
            <RowDefinition Height="18" />
            <RowDefinition Height="62" />
          </Grid.RowDefinitions>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border Width="28"
                    Height="20"
                    CornerRadius="6"
                    Background="#223027"
                    BorderBrush="#335A43"
                    BorderThickness="1"
                    Margin="0,0,8,0">
              <TextBlock Text="{Binding Label}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource AccentBrush}" />
            </Border>

            <TextBlock Grid.Column="1"
                       Text="{Binding DisplayTitle}"
                       ToolTip="{Binding DisplayTitle}"
                       Margin="0,0,6,0"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       VerticalAlignment="Center" />

                <Button Grid.Column="2"
                  Content="&#xE74D;"
                  Tag="{Binding}"
                  Click="DeleteStoredPanelButton_Click"
                  Style="{StaticResource StoredDeleteButton}"
                  VerticalAlignment="Top"
                  IsEnabled="{Binding HasContent}" />
          </Grid>

          <TextBlock Grid.Row="1"
                     Text="{Binding ShortPath}"
                     Margin="0,3,0,0"
                     Foreground="{StaticResource MutedTextBrush}"
                     FontSize="10" />

              <Grid Grid.Row="2" Margin="0,6,0,0" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Button Grid.Row="0"
                  Grid.Column="0"
                    Content="A"
                    Tag="{Binding}"
                    CommandParameter="A"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="0,0,4,4"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="0"
                  Grid.Column="1"
                    Content="B"
                    Tag="{Binding}"
                    CommandParameter="B"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="4,0,0,4"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="1"
                  Grid.Column="0"
                    Content="C"
                    Tag="{Binding}"
                    CommandParameter="C"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="0,4,4,0"
                    IsEnabled="{Binding HasContent}" />
                <Button Grid.Row="1"
                  Grid.Column="1"
                    Content="D"
                    Tag="{Binding}"
                    CommandParameter="D"
                    Click="ShowStoredPanelButton_Click"
                    Style="{StaticResource StoredAssignButton}"
                  HorizontalAlignment="Stretch"
                  Margin="4,4,0,0"
                    IsEnabled="{Binding HasContent}" />
          </Grid>
        </Grid>
      </Border>
    </DataTemplate>

    <DataTemplate x:Key="StoredPanelPageTemplate" DataType="{x:Type models:StoredPanelPage}">
      <ItemsControl ItemsSource="{Binding Slots}"
                    ItemTemplate="{StaticResource StoredPanelTemplate}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <UniformGrid Columns="4" />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemContainerStyle>
          <Style TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,4,0" />
          </Style>
        </ItemsControl.ItemContainerStyle>
      </ItemsControl>
    </DataTemplate>
  </Window.Resources>

  <Border x:Name="PanelFrameBorder"
          Background="Transparent"
          BorderBrush="Transparent"
          BorderThickness="0"
          CornerRadius="0">
    <Grid x:Name="RootLayoutGrid" Background="{StaticResource PanelBackgroundBrush}" Margin="8">
    <Grid.RowDefinitions>
      <RowDefinition Height="26" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <Grid Grid.Row="0">
      <TextBlock x:Name="WindowTitleText"
                 Text="Turtle AI Code Quartet Hub"
                 FontWeight="SemiBold"
                 Foreground="{StaticResource TextBrush}" />
      <StackPanel x:Name="TitleBarButtonsPanel"
                  HorizontalAlignment="Right"
                  Orientation="Horizontal">
