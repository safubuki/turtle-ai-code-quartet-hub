                Content="&#xE713;"
                Width="26"
                FontFamily="Segoe MDL2 Assets"
                FontSize="12"
                FontWeight="SemiBold"
                ToolTip="設定"
                Click="SettingsButton_Click"
                Style="{StaticResource ChromeButton}" />
